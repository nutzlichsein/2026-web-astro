---
import Logo from './Logo.astro';

const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/motion', label: 'Motion', active: currentPath === '/motion' },
  { href: '/stills', label: 'Stills', active: currentPath.startsWith('/stills') },
  { href: '/about', label: 'Bio', active: currentPath === '/about' },
];
---

<header class="navbar">
  <div class="container nav-inner">
    <a href="/" class="logo">
        <Logo variant="navbar" />
    </a>
    
    <nav class="desktop-nav">
      {navLinks.map((link) => (
        <a href={link.href} class={link.active ? 'active' : ''}>{link.label}</a>
      ))}
    </nav>

    <div class="nav-actions">
      <button onclick="toggleTheme()" aria-label="Toggle Theme" class="theme-toggle-btn">
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
      </button>

      <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="mobile-nav" id="mobileNav">
    {navLinks.map((link) => (
      <a href={link.href} class={link.active ? 'active' : ''}>{link.label}</a>
    ))}
  </div>
</header>

<style>
  .navbar { 
    padding: 0rem 0;
    position: sticky; 
    top: 0; 
    background: var(--bg-body); 
    z-index: 100; 
    border-bottom: 1px solid var(--border); 
  }
  
  .nav-inner { 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  
  /* Logo styling */
  .logo { 
    display: flex; 
    align-items: center; 
    gap: 0.5rem; 
    text-decoration: none;
    color: var(--text-main);
  }
  
  .logo:hover svg {
  opacity: 0.8;
}
  
  
  /* Desktop navigation */
  .desktop-nav { 
    display: flex; 
    gap: 2rem; 
    align-items: center; 
  }
  
  .desktop-nav a { 
    font-size: 0.8rem; 
    text-transform: uppercase; 
    letter-spacing: 0.08em;
    text-decoration: none;
    color: var(--text-main);
    transition: color 0.3s;
  }
  
  .desktop-nav a:hover { 
    color: var(--accent); 
  }
  
  .desktop-nav a.active { 
    color: var(--accent); 
  }
  
  /* Right side actions (dark mode + hamburger) */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  
  /* Theme toggle button */
  .theme-toggle-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-main);
    cursor: pointer;
    border-radius: 50%;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
  }
  
  .theme-toggle-btn:hover {
    background: var(--border);
    color: var(--accent);
  }
  
  .theme-toggle-btn svg {
    display: none;
  }
  
  html[data-theme="dark"] .theme-toggle-btn .icon-sun {
    display: block;
  }
  
  html[data-theme="light"] .theme-toggle-btn .icon-moon {
    display: block;
  }
  
  /* Hamburger button */
  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-direction: column;
    gap: 5px;
    z-index: 101;
  }
  
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--text-main);
    transition: all 0.3s;
  }
  
  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  
  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }
  
  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }
  
  /* Mobile navigation */
  .mobile-nav {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--bg-body);
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    z-index: 99;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }
  
  .mobile-nav.open {
    display: flex;
    transform: translateX(0);
  }
  
  .mobile-nav a {
    font-size: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--text-main);
    font-family: var(--font-display);
  }
  
  .mobile-nav a:hover,
  .mobile-nav a.active {
    color: var(--accent);
  }
  
  /* Responsive: mobile */
  @media (max-width: 768px) {
    .desktop-nav {
      display: none;
    }
    
    .hamburger {
      display: flex;
    }
    
    
    .logo svg {
      width: 80px;
      height: auto;
    }
    
    .theme-toggle-btn {
      width: 30px;
      height: 30px;
    }
  }
  
  /* Tablet: keep desktop nav */
  @media (min-width: 769px) {
    .mobile-nav {
      display: none !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hamburger = document.getElementById('hamburgerBtn');
    const mobileNav = document.getElementById('mobileNav');
    
    if (hamburger && mobileNav) {
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        mobileNav.classList.toggle('open');
        document.body.style.overflow = mobileNav.classList.contains('open') ? 'hidden' : '';
      });
      mobileNav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('active');
          mobileNav.classList.remove('open');
          document.body.style.overflow = '';
        });
      });
    }
  });
</script>