---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 | Suryo Wibowo">
  <div class="not-found">
    <h1>404</h1>
    <p>Page not found</p>
    <a href="/" class="btn">Back to Home</a>
  </div>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    gap: 1rem;
  }
  .not-found h1 {
    font-size: 6rem;
    font-family: var(--font-display);
    font-weight: 300;
    line-height: 1;
  }
  .not-found p {
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>
