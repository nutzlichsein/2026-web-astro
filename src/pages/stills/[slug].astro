---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getPhotographyImageUrl } from '../../utils/images';

export async function getStaticPaths() {
  const projects = await getCollection('photography');
  return projects.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, subtitle, coverImage, gallery } = entry.data;
---

<Layout title={`${title} | Suryo Wibowo`}>
  <article class="story-container">
    
    <!-- Hero Image -->
    <figure class="hero-img">
      <div class="image-wrapper">
        <img 
          src={getPhotographyImageUrl(entry.slug, coverImage)}
          alt={title} 
          loading="eager"
        />

      </div>
       <figcaption class="hero-caption">
         {title}
         {subtitle && <span class="hero-subtitle">{subtitle}</span>}
       </figcaption>
    </figure>

    <!-- Intro Text -->
    <div class="intro">
      <Content />
    </div>

    <!-- Gallery -->
    {gallery && gallery.length > 0 && (
      <div class="gallery-masonry" id="gallery-masonry">
        {gallery.map((item) => {
          if (item.type === 'image') {
            return (
              <figure 
                class="gallery-item zoomable" 
                class:list={[
                  item.fullWidth && 'full-width',
                  item.caption && 'has-caption'
                ]}
                data-pswp-src={getPhotographyImageUrl(entry.slug, item.src)}
                data-pswp-caption={item.caption || ''}
                data-pswp-alt={item.alt || title}
              >
                <div class="image-wrapper">
                  <img 
                    src={getPhotographyImageUrl(entry.slug, item.src)}
                    alt={item.alt || title}
                    loading="lazy" 
                  />
                  <div class="zoom-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="11" cy="11" r="8"></circle>
                      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                      <line x1="11" y1="8" x2="11" y2="14"></line>
                      <line x1="8" y1="11" x2="14" y2="11"></line>
                    </svg>
                  </div>
                </div>
                {item.caption && (
                  <figcaption class="image-caption">{item.caption}</figcaption>
                )}
              </figure>
            );
          } else if (item.type === 'text') {
            return (
              <div class="gallery-text-block" class:list={[
                item.fullWidth && 'full-width'
              ]}>
                <div class="text-content-wrapper">
                  <div class="text-content" set:html={item.content} />
                </div>
              </div>
            );
          }
          return null;
        })}
      </div>
    )}
  </article>
</Layout>

<style>
  .story-container { 
    max-width: 1240px; 
    margin: 0 auto; 
    padding: 1rem 1rem 1rem 1rem; 
  }
  
  .hero-img { 
    margin-bottom: 1rem;
    } 

.hero-img .image-wrapper {
  position: relative;
  border-radius: 8px;
  overflow: hidden;
}

.hero-img img {
  width: 100%;
  height: auto;
  display: block;
}

.hero-img .image-wrapper::after {
  content: '';
  position: absolute;
  inset: 0;
  background: url('/frame2.svg') no-repeat center / 100% 100%;
  pointer-events: none;
}

html[data-theme="dark"] .hero-img .image-wrapper::after {
  filter: invert(1);
}
  .hero-caption { 
    margin-top: 1rem; 
    font-size: 2.5rem; 
    font-family: var(--font-display); 
    font-weight: 500; 
    color: #434343; 
    text-align: center; 
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    display: block;
    font-size: 1rem;
    font-family: var(--font-body);
    font-weight: 400;
    color: #777;
    margin-top: 0.5rem;
    text-align: center;
  }
  
  /* Dark mode hero caption */
  html[data-theme="dark"] .hero-caption {
    color: #e0e0e0;
  }

  html[data-theme="dark"] .hero-subtitle {
    color: #999;
  }

  .intro { 
    max-width: 75ch; 
    margin: 0 auto 1.5rem; 
    font-size: 1.1rem; 
    line-height: 1.8; 
  }

  /* Masonry Layout */
  .gallery-masonry { 
    column-count: 2; 
    column-gap: 2rem; 
  }
  
  .gallery-item { 
    margin: 0;
    margin-bottom: 2rem;
    break-inside: avoid;
  }
  
  .gallery-item img { 
    width: 100%; 
    height: auto; 
    display: block; 
    border-radius: 4px;
  }
  
  /* Image wrapper for zoom icon */
  .image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
  }
  
  .image-wrapper img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.3s ease;
  }
  
  /* Zoom icon */
  .zoom-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(0, 0, 0, 0.7);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    cursor: pointer;
    color: white;
    pointer-events: none;
  }
  
  .zoomable:hover .zoom-icon {
    opacity: 1;
  }
  
  .zoomable:hover .image-wrapper img {
    transform: scale(1.02);
  }
  
  .zoomable {
    cursor: pointer;
  }
  
  /* Image caption */
  .image-caption {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: #666;
    line-height: 1.4;
    text-align: center;
    font-style: italic;
  }
  
  /* Text block styling */
  .gallery-text-block {
    margin-top: 0;
    margin-bottom: 2rem;
    break-inside: avoid;
  }
  
  .gallery-text-block .text-content-wrapper {
    width: 100%;
    padding-top: 0;
  }
  
  .gallery-text-block .text-content {
    font-size: 1rem;
    line-height: 1.7;
  }
  
  .gallery-text-block .text-content p {
    margin-bottom: 1rem;
    line-height: 1.8;
  }
  
  .gallery-text-block .text-content p:last-child {
    margin-bottom: 0;
  }

  .gallery-text-block .text-content blockquote p {
    margin-bottom: 0.5rem;
  }

  .gallery-text-block .text-content blockquote p:last-child {
    margin-bottom: 0;
  }

  .gallery-text-block .text-content strong {
    color: #000;
    font-weight: 600;
  }

  .gallery-text-block,
  .gallery-text-block .text-content-wrapper,
  .gallery-text-block .text-content,
  .gallery-text-block .text-content p:first-child {
    margin-top: 0;
    padding-top: 0;
  }

  /* Full-width text block */
  .gallery-text-block.full-width {
    column-span: all;
    width: 100%;
    margin: 2rem 0;
    padding: 0rem 0;
    display: flex;
    justify-content: center;
  }
  
  .gallery-text-block.full-width .text-content-wrapper {
    max-width: 85ch;
    width: 100%;
    padding: 0 1.5rem;
  }
  
  .gallery-text-block.full-width .text-content {
    font-size: 1.1rem;
    line-height: 1.8;
  }
  
  /* Full-width image items */
  .gallery-item.full-width {
    column-span: all;
    width: 100%;
    margin-bottom: 2rem;
  }
  
  .gallery-item.full-width img {
    width: 100%;
    max-height: 80vh;
    object-fit: cover;
  }
  
  /* Dark mode */
  html[data-theme="dark"] .gallery-text-block.full-width {
    background: transparent;
  }
  
  html[data-theme="dark"] .image-caption {
    color: #aaa;
  }
  
html[data-theme="dark"] .gallery-text-block .text-content strong {
  color: #fff;
}
  
  html[data-theme="dark"] .zoom-icon {
    background: rgba(255, 255, 255, 0.2);
  }
  
  /* ============ MOBILE ============ */
  @media (max-width: 768px) {
    .hero-img .image-wrapper {
      border-radius: 0;
    }
    .gallery-masonry { column-count: 1; }
    .gallery-item.full-width,
    .gallery-text-block.full-width { 
      column-span: none; 
    }
    
    .gallery-text-block.full-width {
      padding: 1.5rem 0;
    }
    
    .gallery-text-block.full-width .text-content-wrapper {
      padding: 0 1rem;
    }
    
    /* Intro text */
    .intro {
      font-size: 0.9rem;
      line-height: 1.7;
    }
    
    /* Text in gallery (non-fullwidth) */
    .gallery-text-block .text-content {
      font-size: 0.85rem;
      line-height: 1.6;
    }
    
    /* Text content full-width */
    .gallery-text-block.full-width .text-content {
      font-size: 0.9rem;
      line-height: 1.7;
    }
    
    /* Hero caption (project title) */
    .hero-caption {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .hero-subtitle {
      font-size: 0.85rem;
      margin-top: 0.35rem;
    }
    
    /* Image caption */
    .image-caption {
      font-size: 0.7rem;
    }
    
    /* Intro headings */
    .intro h1, .intro h2, .intro h3 {
      font-size: 1.2rem;
    }
    
    /* Smaller paragraph spacing */
    .intro p,
    .gallery-text-block .text-content p {
      margin-bottom: 1rem;
    }
    
    /* Reset first gallery text block margin */
    .gallery-text-block:first-of-type {
      margin-top: 0 !important;
      padding-top: 0 !important;
    }
  }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/photoswipe.css" />

<script is:inline src="https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/umd/photoswipe.umd.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/umd/photoswipe-lightbox.umd.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const lightbox = new PhotoSwipeLightbox({
      gallery: '#gallery-masonry',
      children: '.zoomable',
      pswpModule: PhotoSwipe,
      bgOpacity: 0.9,
      zoom: true,
      counter: true,
      arrowKeys: true,
    });
    
    lightbox.addFilter('itemData', (itemData, index) => {
      const elements = document.querySelectorAll('.zoomable');
      if (elements[index]) {
        const el = elements[index];
        itemData.src = el.getAttribute('data-pswp-src') || '';
        itemData.w = 1200;
        itemData.h = 800;
        itemData.alt = el.getAttribute('data-pswp-alt') || '';
        itemData.title = el.getAttribute('data-pswp-caption') || '';
      }
      return itemData;
    });
    
    lightbox.init();
  });
</script>

<style is:global>
  /* PhotoSwipe caption styling */
  .pswp__caption {
    position: absolute;
    bottom: 20px;
    left: 0;
    right: 0;
    text-align: center;
    background: rgba(0, 0, 0, 0.6);
    padding: 12px 20px;
    color: white;
    font-size: 14px;
    font-style: italic;
  }
  
  .pswp__caption-center {
    max-width: 80%;
    margin: 0 auto;
  }
  
  @media (max-width: 768px) {
    .pswp__caption {
      font-size: 12px;
      padding: 8px 12px;
    }
  }
</style>